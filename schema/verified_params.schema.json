{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mechproof/schemas/verified_params.schema.json",
  "title": "MechProof verified parameters",
  "description": "Parameters of a DraftedCase whose moldability has been mathematically proven in Lean 4. All distances in millimetres; draftDeg is the inner-side-wall taper from the +Z pull axis (degrees).",
  "type": "object",
  "required": ["length", "width", "height", "thickness", "draftDeg"],
  "additionalProperties": false,
  "properties": {
    "length":    { "type": "number", "exclusiveMinimum": 0 },
    "width":     { "type": "number", "exclusiveMinimum": 0 },
    "height":    { "type": "number", "exclusiveMinimum": 0 },
    "thickness": { "type": "number", "exclusiveMinimum": 0 },
    "draftDeg":  { "type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 90 }
  }
}
